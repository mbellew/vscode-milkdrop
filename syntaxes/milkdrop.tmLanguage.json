{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Milkdrop Preset",
  "scopeName": "source.milkdrop",
  "fileTypes": ["milk"],
  "patterns": [
    { "include": "#section" },
    { "include": "#comment" },
    { "include": "#shader-line" },
    { "include": "#code-line" },
    { "include": "#kv-line" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.milkdrop"
    },
    "section": {
      "match": "^\\s*(\\[)([^\\]]+)(\\])\\s*$",
      "captures": {
        "1": { "name": "punctuation.section.brackets.milkdrop" },
        "2": { "name": "entity.name.section.milkdrop" },
        "3": { "name": "punctuation.section.brackets.milkdrop" }
      }
    },
    "shader-line": {
      "match": "^(warp|comp)(_)(\\d+)(=)(`)(.*)$",
      "captures": {
        "1": { "name": "keyword.other.shader.milkdrop" },
        "2": { "name": "punctuation.separator.milkdrop" },
        "3": { "name": "constant.numeric.line-index.milkdrop" },
        "4": { "name": "keyword.operator.assignment.milkdrop" },
        "5": { "name": "punctuation.definition.string.begin.milkdrop" },
        "6": {
          "name": "meta.embedded.block.hlsl.milkdrop",
          "patterns": [{ "include": "source.hlsl" }]
        }
      }
    },
    "code-line": {
      "match": "^(per_frame|per_pixel|per_frame_init|wavecode|shapecode|wave|shape)(_)(\\d+)(?:(_)([a-zA-Z_][a-zA-Z0-9_]*))?(=)(.*)$",
      "captures": {
        "1": { "name": "keyword.other.code.milkdrop" },
        "2": { "name": "punctuation.separator.milkdrop" },
        "3": { "name": "constant.numeric.line-index.milkdrop" },
        "4": { "name": "punctuation.separator.milkdrop" },
        "5": { "name": "variable.other.property.milkdrop" },
        "6": { "name": "keyword.operator.assignment.milkdrop" },
        "7": {
          "name": "meta.embedded.block.expression.milkdrop",
          "patterns": [
            { "include": "#numeric" },
            { "include": "#expression-keyword" }
          ]
        }
      }
    },
    "kv-line": {
      "match": "^([A-Za-z_][A-Za-z0-9_]*)(=)(.*)$",
      "captures": {
        "1": { "name": "variable.other.key.milkdrop" },
        "2": { "name": "keyword.operator.assignment.milkdrop" },
        "3": {
          "patterns": [{ "include": "#numeric" }, { "include": "#string-value" }]
        }
      }
    },
    "numeric": {
      "match": "\\b-?\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.milkdrop"
    },
    "expression-keyword": {
      "match": "\\b(if|above|below|equal|sin|cos|tan|sqrt|abs|log|pow|min|max|int|rand|sigmoid|bnot|band|bor|atan2|atan|exp)\\b",
      "name": "support.function.milkdrop"
    },
    "string-value": {
      "match": ".+",
      "name": "string.unquoted.milkdrop"
    }
  }
}